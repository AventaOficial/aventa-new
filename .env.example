# Supabase (obligatorio)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Upstash Redis (rate limiting: obligatorio en producción para límites globales; sin esto se usa fallback en memoria por instancia)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu-token

# Resend (correos diario/semanal)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=AVENTA <notificaciones@aventaofertas.com>
# Logo en cabecera del correo (URL pública; opcional; mejora identidad en Gmail)
EMAIL_LOGO_URL=https://aventaofertas.com/logo-email.png

# URL pública de la app (usado en SEO, emails, metadata)
NEXT_PUBLIC_APP_URL=https://aventaofertas.com

# Mercado Libre — tag de afiliado de la plataforma (parámetro ?tag= en enlaces ML).
# En producción define al menos una: NEXT_PUBLIC_ para que “Cazar” en el cliente aplique el tag;
# ML_AFFILIATE_TAG opcional en servidor (mismo valor) para normalizar URLs al guardar.
# Enlaces meli.la/… (colaboradores ML) se expanden al guardar a la URL del artículo + ?tag=.
# NEXT_PUBLIC_ML_AFFILIATE_TAG=tu-tag-de-socio
# ML_AFFILIATE_TAG=tu-tag-de-socio

# --- Amazon Associates (cuando ya te aprobaron) ---
# 1) Entra a https://affiliate-program.amazon.com/ (o la consola de tu país) → Associates Central.
# 2) Cuenta / “Manage your tracking IDs” (o “Tracking IDs”): ahí ves o creas tu ID (ej. tunombre-20, miwebmx-21).
# 3) Ese ID es el parámetro ?tag= de los enlaces. Pon el MISMO valor en ambas líneas (servidor + cliente):
# NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=tu-tracking-id
# AMAZON_ASSOCIATE_TAG=tu-tracking-id
# Enlaces amazon.com.mx: la app añade ?tag= si falta. Tras desplegar, prueba una URL de producto y verifica en la barra de direcciones.
#
# AliExpress: el programa “portals” usa aff_fcid y no siempre está disponible por región; si no tienes afiliación activa, deja sin definir ALIEXPRESS_* (no pasa nada).
# Temu: algunos paneles solo listan sitios tipo “cupones”; si no aparece tu dominio, prueba registrar el canal como web propia o contacta soporte del programa partner. Sin PID válido, no definas TEMU_*.
# Walmart / Shein: igual que arriba; solo si el programa te dio parámetros concretos.
# NEXT_PUBLIC_ALIEXPRESS_AFF_FCID=…
# ALIEXPRESS_AFF_FCID=…
# WALMART_AFFILIATE_QUERY=wmlspartner=…&sourceid=…
# NEXT_PUBLIC_WALMART_AFFILIATE_QUERY=…
# SHEIN_AFF_ID=…
# NEXT_PUBLIC_SHEIN_AFF_ID=…
# TEMU_AFFILIATE_RP_PID=…
# NEXT_PUBLIC_TEMU_AFFILIATE_RP_PID=…
#
# Libro mayor interno (comisiones importadas): migración docs/supabase-migrations/affiliate_platform_ledger.sql
# GET/POST /api/admin/affiliate-ledger (Bearer token owner/admin) para registrar totales de reportes descargados.

# Bot de ingesta v3 — GET /api/cron/bot-ingest (Authorization: Bearer CRON_SECRET o ?secret=).
# Vercel Hobby: los crons del proyecto solo pueden ejecutarse como máximo 1 vez al día; por eso NO incluimos
# bot-ingest en vercel.json por defecto (el deploy fallaría con */15 * * * *).
# Opciones: (1) Vercel Pro → añade en vercel.json { "path": "/api/cron/bot-ingest", "schedule": "*/15 * * * *" }
# (2) Cron externo gratuito (p. ej. cron-job.org) llamando GET https://TU_DOMINIO/api/cron/bot-ingest?secret=TU_CRON_SECRET cada 15 min
# (3) Panel Admin → Operaciones/Trabajo → «Ejecutar ahora» (manual).
# Publica 1–3 ofertas por corrida (aleatorio), con boost matutino (~7:00 hora local) hasta BOT_INGEST_BOOST_MAX.
# Tope diario BOT_INGEST_DAILY_MAX (p. ej. 120). Alta puntuación → status approved; media → pending.
# Auto-aprobación por score (default sí). Solo moderación humana: BOT_INGEST_AUTO_APPROVE=0 → docs/BOT_MODO_SOLO_MODERACION.md
# BOT_INGEST_AUTO_APPROVE=0
# BOT_INGEST_ENABLED=1
# BOT_INGEST_USER_ID=<uuid usuario bot en Supabase Auth>
# BOT_INGEST_TIMEZONE=America/Mexico_City
# BOT_INGEST_NORMAL_MAX_MIN=1
# BOT_INGEST_NORMAL_MAX_MAX=3
# BOT_INGEST_BOOST_MAX=20
# BOT_INGEST_BOOST_LOCAL_HOUR=7
# BOT_INGEST_BOOST_LOCAL_MINUTE_END=30
# BOT_INGEST_DAILY_MAX=120
# BOT_INGEST_CANDIDATE_POOL_MAX=48
# BOT_INGEST_MIN_DISCOUNT_PERCENT=20
# BOT_INGEST_AUTO_APPROVE_MIN_SCORE=78
# BOT_INGEST_REJECT_BELOW_SCORE=42
# Pesos score (descuento,popularidad,rating,categoría,precio) normalizados internamente, ej: 1,1,1,1,1
# BOT_INGEST_SCORE_WEIGHTS=1,1,1,1,1
# BOT_INGEST_CATEGORY=tecnologia
# BOT_INGEST_URLS=https://meli.la/...\nhttps://www.mercadolibre.com.mx/...
#
# --- Mercado Libre (sites/MLM/search + /items?ids=) ---
# BOT_INGEST_DISCOVER_ML=1
# BOT_INGEST_ML_QUERIES=laptop\nssd nvme\nmonitor 27
# BOT_INGEST_ML_CATEGORY_IDS=MLM1144
# BOT_INGEST_ML_TECH_CATEGORY_IDS=MLM1648,MLM1000,MLM1144,MLM1574
# BOT_INGEST_ML_USE_DEFAULT_QUERIES=1
# BOT_INGEST_ML_SEARCH_LIMIT=50
# BOT_INGEST_ML_MAX_COLLECT=120
# Orden “trending” en búsqueda: sold_quantity_desc (documentación ML)
# BOT_INGEST_ML_SORT_TRENDING=sold_quantity_desc
# BOT_INGEST_ML_MIN_SOLD=50
# BOT_INGEST_ML_FETCH_REVIEWS=1
# BOT_INGEST_ML_REVIEW_FETCH_MAX=18
#
# --- Calidad / reseñas (Amazon vía JSON-LD en HTML; ML vía API de reviews si FETCH_REVIEWS) ---
# BOT_INGEST_MIN_RATING=4
# BOT_INGEST_MIN_RATING_REVIEWS=5
# Regex opcionales sobre título (peligroso si mal formados)
# BOT_INGEST_TITLE_RE_GENERIC=
# BOT_INGEST_TITLE_RE_SPAM=
#
# --- Amazon (ASIN → /dp/ + parse HTML) ---
# BOT_INGEST_AMAZON_ASINS=B0XXXXXXXXX,B0YYYYYYYYY
# BOT_INGEST_AMAZON_DP_BASE=https://www.amazon.com.mx/dp/
#
# Pausar sin tocar Vercel: en Supabase tabla app_config key bot_ingest_paused value true (jsonb boolean),
# o desde la UI en Admin → Operaciones → Trabajo (interruptor "Permitir ejecución del bot").
#
# Segunda automatización (RSS): reservado; sin efecto hasta implementar parser.
# BOT_INGEST_RSS_ENABLED=0
# BOT_INGEST_RSS_URLS=

# Secreto para proteger endpoints cron de Vercel (obligatorio en producción)
CRON_SECRET=tu-cron-secret

# Zona horaria para ventanas del digest (default America/Mexico_City)
# DIGEST_TIMEZONE=America/Mexico_City

# Alertas de integridad (opcionales)
# Email destino para alertas del cron /api/cron/system-integrity (requiere RESEND_API_KEY)
SYSTEM_ALERT_EMAIL_TO=owner@aventaofertas.com
# Webhook para Slack/Discord/Make/Zapier (POST JSON cuando falla integridad)
SYSTEM_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Rate limits adaptativos (opcionales)
# Multiplicador global para presets (ej. 2 = duplica todos los límites)
RATE_LIMIT_MULTIPLIER=1
# Overrides por preset (req/min)
RATE_LIMIT_DEFAULT_PER_MIN=30
RATE_LIMIT_FEED_PER_MIN=120
RATE_LIMIT_EVENTS_PER_MIN=60
RATE_LIMIT_OFFERS_PER_MIN=5
RATE_LIMIT_COMMENTS_PER_MIN=20
RATE_LIMIT_REPORTS_PER_MIN=10
RATE_LIMIT_PARSE_OFFER_PER_MIN=20

# Estrategia de escritura de eventos (view/outbound/share):
# - direct: escribe directo en offer_events
# - adaptive: intenta directo, si falla encola (recomendado)
# - queue: encola siempre y procesa con endpoint owner
EVENT_WRITE_MODE=adaptive
# Cantidad de jobs a procesar por corrida de cron de cola
WRITE_QUEUE_CRON_BATCH=300
