# Supabase (obligatorio)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Upstash Redis (rate limiting: obligatorio en producción para límites globales; sin esto se usa fallback en memoria por instancia)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu-token

# Resend (correos diario/semanal)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=AVENTA <notificaciones@aventaofertas.com>
# Logo en cabecera del correo (URL pública; opcional; mejora identidad en Gmail)
EMAIL_LOGO_URL=https://aventaofertas.com/logo-email.png

# URL pública de la app (usado en SEO, emails, metadata)
NEXT_PUBLIC_APP_URL=https://aventaofertas.com

# Mercado Libre — tag de afiliado de la plataforma (parámetro ?tag= en enlaces ML).
# En producción define al menos una: NEXT_PUBLIC_ para que “Cazar” en el cliente aplique el tag;
# ML_AFFILIATE_TAG opcional en servidor (mismo valor) para normalizar URLs al guardar.
# NEXT_PUBLIC_ML_AFFILIATE_TAG=tu-tag-de-socio
# ML_AFFILIATE_TAG=tu-tag-de-socio

# Secreto para proteger endpoints cron de Vercel (obligatorio en producción)
CRON_SECRET=tu-cron-secret

# Zona horaria para ventanas del digest (default America/Mexico_City)
# DIGEST_TIMEZONE=America/Mexico_City

# Alertas de integridad (opcionales)
# Email destino para alertas del cron /api/cron/system-integrity (requiere RESEND_API_KEY)
SYSTEM_ALERT_EMAIL_TO=owner@aventaofertas.com
# Webhook para Slack/Discord/Make/Zapier (POST JSON cuando falla integridad)
SYSTEM_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Rate limits adaptativos (opcionales)
# Multiplicador global para presets (ej. 2 = duplica todos los límites)
RATE_LIMIT_MULTIPLIER=1
# Overrides por preset (req/min)
RATE_LIMIT_DEFAULT_PER_MIN=30
RATE_LIMIT_FEED_PER_MIN=120
RATE_LIMIT_EVENTS_PER_MIN=60
RATE_LIMIT_OFFERS_PER_MIN=5
RATE_LIMIT_COMMENTS_PER_MIN=20
RATE_LIMIT_REPORTS_PER_MIN=10
RATE_LIMIT_PARSE_OFFER_PER_MIN=20

# Estrategia de escritura de eventos (view/outbound/share):
# - direct: escribe directo en offer_events
# - adaptive: intenta directo, si falla encola (recomendado)
# - queue: encola siempre y procesa con endpoint owner
EVENT_WRITE_MODE=adaptive
# Cantidad de jobs a procesar por corrida de cron de cola
WRITE_QUEUE_CRON_BATCH=300
